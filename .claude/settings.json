{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npx tsc:*)",
      "WebFetch(domain:react-aria.adobe.com)",
      "WebFetch(domain:react-spectrum.adobe.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "npm run fmt",
        "cwd": "${workspaceFolder}",
        "timeout": 30
      }
    ]
  }
}
